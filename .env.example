# FraudGuard Configuration
FRAUDGUARD_API_KEY=fg_your_api_key_here
FRAUDGUARD_DEBUG=true
FRAUDGUARD_USE_FAKE_REDIS=true
FRAUDGUARD_DATABASE_URL=sqlite+aiosqlite:///./data/fraudguard.db

# Stripe (required for /v1/charge and webhook endpoints)
FRAUDGUARD_STRIPE_API_KEY=sk_test_your_stripe_key
FRAUDGUARD_STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Redis (set USE_FAKE_REDIS=false for production)
FRAUDGUARD_REDIS_URL=redis://localhost:6379/0

# Risk thresholds (0.0 - 1.0)
FRAUDGUARD_FLAG_THRESHOLD=0.5
FRAUDGUARD_BLOCK_THRESHOLD=0.8

# Velocity limits
FRAUDGUARD_VELOCITY_IP_1M=10
FRAUDGUARD_VELOCITY_IP_1H=50
FRAUDGUARD_VELOCITY_CARD_1H=5
FRAUDGUARD_VELOCITY_EMAIL_1H=20

# High-risk countries (ISO alpha-2)
FRAUDGUARD_HIGH_RISK_COUNTRIES=["NG","GH","PK","BD","VN"]
